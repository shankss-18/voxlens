{
  "manifest_version": 3,
  "name": "Voxlens",
  "version": "1.1",
  "description": "Talk to any webpage using your voice",

  "icons": {
    "16": "icons/logo.png",
    "32": "icons/logo.png",
    "48": "icons/logo.png",
    "128": "icons/logo.png"
  },

  "action": {
    "default_title": "VoxLens",
    "default_icon": "icons/logo.png"
  },

  "background": {
    "service_worker": "background.js"
  },

  "permissions": [
    "activeTab",
    "scripting",
    "tabs",
    "storage"
  ],

  "host_permissions": [
    "<all_urls>",
    "https://www.google.com/"
  ],

  "web_accessible_resources": [
    {
      "resources": [
        "popup.html",
        "popup.js",
        "ui.js",
        "pills.js",
        "mic-permission.html",
        "mic-permission.js"
      ],
      "matches": ["<all_urls>"]
    }
  ],

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "all_frames": true
    }
  ]
}
